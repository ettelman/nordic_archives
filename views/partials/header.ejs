<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Secure document archiving and backup solutions for regulated businesses.">
  <title><%= title %> | <%= company.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-content">
      <div class="brand">
        <a href="/" class="brand-mark">
          <img src="/images/nordic_logo.png" alt="Nordic Archives" class="brand-logo">
        </a>
      </div>
      <nav class="nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/services" class="nav-link">Services</a>
        <a href="/about" class="nav-link">About</a>
        <a href="/contact" class="nav-link">Contact</a>
        <% if (user) { %>
          <span class="nav-user">
            <span class="nav-user-name"><%= user.fullName ? user.fullName : user.email %></span>
            <span class="nav-user-role"><%= user.role.replace('_', ' ') %></span>
          </span>
          <a href="/portal" class="nav-link">Portal</a>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="nav-link">Admin</a>
          <% } %>
          <a href="/logout" class="nav-link nav-link-primary">Sign out</a>
        <% } else { %>
          <a href="/login" class="nav-link nav-link-primary">Login</a>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="site-main">
