<%- include('../partials/header', { title: title }) %>
<section class="page-hero">
  <div class="container split">
    <div>
      <p class="eyebrow">Services</p>
      <h1>Enterprise-grade archiving with accountable delivery.</h1>
      <p class="lead">Our services support long-term retention, secure access, and reliable recovery for business-critical documents.</p>
    </div>
    <div class="image-slot image-slot-wide image-frame">
      <img src="/images/andersson.png" alt="Accountable service delivery">
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid">
      <article class="card">
        <h3>Secure digital archiving</h3>
        <p>Encrypted storage and retention schedules designed for internal governance.</p>
        <p class="card-meta">Includes indexing, metadata capture, and role-based access controls.</p>
      </article>
      <article class="card">
        <h3>Physical-to-digital intake</h3>
        <p>Digitization workflows for legacy records with verified scanning and classification.</p>
        <p class="card-meta">Ideal for finance, legal, and procurement departments.</p>
      </article>
      <article class="card">
        <h3>Business continuity backup</h3>
        <p>Redundant storage and recovery planning with documented objectives and testing cadence.</p>
        <p class="card-meta">Supports multi-site operations and critical services.</p>
      </article>
      <article class="card">
        <h3>Audit readiness</h3>
        <p>Comprehensive reporting packages and retrieval records prepared for review.</p>
        <p class="card-meta">Exportable in formats used by auditors and regulators.</p>
      </article>
    </div>
  </div>
</section>

<section class="section section-muted">
  <div class="container split">
    <div>
      <h2>Service levels that match your governance needs</h2>
      <p>Tiered support packages provide defined escalation, reporting cadence, and executive summaries.</p>
    </div>
    <div class="panel">
      <h3>Plan a service review</h3>
      <p>We can provide a structured assessment of your retention program and recommend next steps.</p>
      <a class="button" href="/contact">Schedule a consultation</a>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
