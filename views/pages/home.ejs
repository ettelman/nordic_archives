<%- include('../partials/header', { title: title }) %>
<section class="hero">
  <div class="container hero-content">
    <div>
      <p class="eyebrow">Trusted archiving for Nordic enterprises</p>
      <h1>Secure document retention built for regulated operations.</h1>
      <p class="lead">Nordic Archives delivers retention, backup, and retrieval services for organizations that require audited control of critical records.</p>
      <div class="hero-actions">
        <a class="button" href="/services">Explore services</a>
        <a class="button button-secondary" href="/contact">Request a consultation</a>
      </div>
    </div>
    <div class="image-slot image-slot-tall image-frame">
      <img src="/images/archive.png" alt="Archived document storage facility">
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2>Services designed for compliance-driven teams</h2>
    <p class="section-lead">We support legal, finance, and operations teams with predictable retention and transparent reporting.</p>
    <div class="grid">
      <article class="card">
        <h3>Document archiving</h3>
        <p>Structured retention with secure indexing, controlled access, and verified chain-of-custody workflows.</p>
      </article>
      <article class="card">
        <h3>Managed backup</h3>
        <p>Policy-driven backups with recovery testing and lifecycle management for critical records.</p>
      </article>
      <article class="card">
        <h3>Regulatory reporting</h3>
        <p>Audit-ready reporting packages aligned with internal governance and external review requirements.</p>
      </article>
    </div>
  </div>
</section>

<section class="section section-muted">
  <div class="container split">
    <div>
      <h2>Operational control without disruption</h2>
      <p>Our onboarding model aligns with existing processes so teams can modernize retention without disruption.</p>
      <ul class="list">
        <li>Dedicated service manager and escalation path</li>
        <li>Documented recovery objectives and tests</li>
      </ul>
    </div>
    <div class="panel">
      <h3>Client portal access</h3>
      <p>Authorized stakeholders can review storage activity, request retrievals, and confirm retention actions.</p>
      <a class="text-link" href="/login">Sign in to the client portal</a>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
